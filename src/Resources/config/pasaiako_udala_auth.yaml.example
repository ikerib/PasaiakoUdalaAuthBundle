# PasaiakoUdalaAuthBundle - Ejemplo de configuracion
#
# Copia este fichero a config/packages/pasaiako_udala_auth.yaml
# y ajusta los valores para tu entorno.

pasaiako_udala_auth:

    # --- Servidor LDAP ---
    server:
        host: '%env(LDAP_HOST)%'
        port: '%env(int:LDAP_PORT)%'
        encryption: '%env(LDAP_ENCRYPTION)%'       # none, ssl o tls
        base_dn: '%env(LDAP_BASE_DN)%'
        user_dn_pattern: '%env(LDAP_USER_DN_PATTERN)%'
        bind_dn: '%env(LDAP_BIND_DN)%'
        bind_password: '%env(LDAP_BIND_PASSWORD)%'

    # --- Mapeo de grupos LDAP a roles Symfony ---
    role_mapping:
        informatika: ROLE_ADMIN
        GGBB: ROLE_KUDEATU
        langilea: ROLE_USER

    default_role: ROLE_USER

    # --- Busqueda de grupos ---
    group_search:
        enabled: true
        base_dn: null
        filter: '(member={user_dn})'
        recursive: true

    # --- Campo DNI (para autenticacion por certificado) ---
    dni_field: employeeID

    # --- Atributos LDAP a recuperar ---
    user_attributes:
        - department
        - displayName
        - extensionName
        - mail
        - preferredLanguage
        - description

    # --- Cache (0 = desactivado) ---
    cache_ttl: 0

    # --- Template base para las vistas del bundle ---
    base_template: base.html.twig

    # --- Nombres de rutas ---
    routes:
        home: app_home
        login_selector: app_login
        login_ldap: app_login_ldap
        oauth_connect: oauth_connect
        oauth_check: oauth_check
